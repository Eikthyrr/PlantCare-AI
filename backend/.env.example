# ============================================
# PlantCare AI - Environment Variables
# ============================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
#
# Untuk mendapatkan API Key Google Gemini:
# 1. Kunjungi https://aistudio.google.com/apikey
# 2. Buat API Key baru
# 3. Salin dan tempel di bawah ini
# ============================================

GEMINI_API_KEY=your_gemini_api_key_here
